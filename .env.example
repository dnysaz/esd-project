# ============ ESD Classroom - Environment Variables ============
# Copy this file to .env.local and fill in the values

# Supabase Project URL (find in Supabase Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon/Public Key (find in Supabase Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (for admin operations - keep SERVER-SIDE only!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (for auth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
